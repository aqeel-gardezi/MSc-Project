# ---- Data files (too large / not for version control) ----
data/raw/*
data/processed/*
data/external/*
!data/**/.gitkeep

# ---- Trained models (large binary files) ----
models/*
!models/.gitkeep

# ---- Credentials & secrets (NEVER commit these) ----
*.env
kaggle.json
ebay_credentials.json
config_secret.py

# ---- Python ----
__pycache__/
*.py[cod]
.ipynb_checkpoints/
venv/
env/
.venv/

# ---- Outputs (optional — keep figures, ignore bulky results) ----
outputs/results/*.pkl
outputs/results/*.csv

# ---- OS files ----
.DS_Store
Thumbs.db
